---
interface Props {
  activePage: 'menu' | 'grades' | 'buses' | 'schedule' | 'apuntes';
}

const { activePage } = Astro.props;

const navItems = [
  { id: 'menu' as const, label: 'Inicio', icon: 'fa-house', href: '/' },
  { id: 'buses' as const, label: 'Buses', icon: 'fa-bus', href: '/buses' },
  { id: 'schedule' as const, label: 'Horario', icon: 'fa-calendar-alt', href: '/schedule' },
];

const isNotasGroup = activePage === 'grades' || activePage === 'apuntes';

const dropdownItems = [
  { id: 'grades' as const, label: 'Control de Notas', icon: 'fa-chart-pie', href: '/grades' },
  { id: 'apuntes' as const, label: 'Apuntes', icon: 'fa-sticky-note', href: '/apuntes' },
];
---

<nav class="fixed top-0 left-0 right-0 z-50 bg-white/80 dark-nav backdrop-blur-xl border-b border-slate-200/60 shadow-sm">
  <div class="max-w-6xl mx-auto px-4 sm:px-6">
    <div class="flex items-center justify-between h-16">
      <a href="/" class="flex items-center gap-3 group">
        <div class="w-9 h-9 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-xl flex items-center justify-center text-white shadow-lg group-hover:shadow-xl transition-shadow">
          <i class="fas fa-graduation-cap text-sm"></i>
        </div>
        <span class="text-lg font-bold bg-gradient-to-r from-slate-800 to-slate-600 dark-logo-text bg-clip-text text-transparent">InfoU</span>
      </a>
      
      <div class="flex items-center gap-1 bg-slate-100/80 dark-nav-pill p-1 rounded-xl">
        {navItems.map((item) => (
          <a
            href={item.href}
            class={`flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${
              activePage === item.id
                ? 'bg-white dark-nav-active text-indigo-600 shadow-sm'
                : 'text-slate-500 dark-nav-inactive hover:text-slate-700 hover:bg-white/50'
            }`}
          >
            <i class={`fas ${item.icon} text-xs`}></i>
            <span class="hidden sm:inline">{item.label}</span>
          </a>
        ))}

        <!-- Notas dropdown -->
        <div class="relative" id="notasDropdown">
          <button id="notasDropdownBtn" class={`flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium transition-all duration-200 ${
            isNotasGroup
              ? 'bg-white dark-nav-active text-indigo-600 shadow-sm'
              : 'text-slate-500 dark-nav-inactive hover:text-slate-700 hover:bg-white/50'
          }`}>
            <i class="fas fa-pencil-alt text-xs"></i>
            <span class="hidden sm:inline">Notas</span>
            <i id="notasChevron" class="fas fa-chevron-down text-[8px] transition-transform duration-200"></i>
          </button>

          <div id="notasDropdownMenu" class="hidden absolute top-full right-0 mt-1 bg-white dark-surface rounded-xl border border-slate-200/80 dark-border shadow-xl py-1.5 min-w-[200px] z-[60]">
            {dropdownItems.map((item) => (
              <a
                href={item.href}
                class={`flex items-center gap-3 px-4 py-2.5 mx-1 rounded-lg text-sm font-medium transition-all ${
                  activePage === item.id
                    ? 'bg-indigo-50 dark-nav-active text-indigo-600'
                    : 'text-slate-600 dark-text-secondary hover:bg-slate-50 dark-hover-surface'
                }`}
              >
                <i class={`fas ${item.icon} text-xs w-4 text-center`}></i>
                {item.label}
              </a>
            ))}
          </div>
        </div>

        <button id="themeToggle" onclick="window.toggleTheme()" class="w-9 h-9 flex items-center justify-center rounded-lg text-slate-400 dark-theme-btn hover:bg-slate-200 transition-all ml-1" aria-label="Cambiar tema">
          <i id="themeIcon" class="fas fa-moon"></i>
        </button>
      </div>
    </div>
  </div>
</nav>

<script>
  document.addEventListener('astro:page-load', function() {
    var menu = document.getElementById('notasDropdownMenu');
    var chevron = document.getElementById('notasChevron');
    if (!menu) return;

    var handler = function(e) {
      var btn = document.getElementById('notasDropdownBtn');
      if (btn && btn.contains(e.target)) {
        e.stopPropagation();
        var open = !menu.classList.contains('hidden');
        menu.classList.toggle('hidden', open);
        if (chevron) chevron.style.transform = open ? '' : 'rotate(180deg)';
      } else if (menu.contains(e.target)) {
        e.stopPropagation();
      } else if (!menu.classList.contains('hidden')) {
        menu.classList.add('hidden');
        if (chevron) chevron.style.transform = '';
      }
    };

    document.removeEventListener('click', window.__navHandler);
    window.__navHandler = handler;
    document.addEventListener('click', window.__navHandler);
  });
</script>
