function simplifyTime(t: string): string {
  const match = t.match(/(\d{1,2}):(\d{2})\s*(a\.m\.|p\.m\.|m\.d\.)/);
  if (!match) return t;
  let h = parseInt(match[1], 10);
  const m = match[2];
  const suffix = match[3];
  if (suffix === 'p.m.' && h !== 12) h += 12;
  if (suffix === 'a.m.' && h === 12) h = 0;
  return h + ':' + m;
}

function makeDir(label: string, desc: string, icon: string, rawTimes: string[]): Direction {
  return {
    label,
    desc,
    icon,
    times: rawTimes.map(simplifyTime),
    displayTimes: rawTimes,
  };
}

