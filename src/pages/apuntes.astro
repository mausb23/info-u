---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
---

<BaseLayout title="Apuntes" activePage="apuntes">
  <Nav activePage="apuntes" />
  
  <main class="pt-16">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 sm:py-12">
      <!-- Dashboard -->
      <div class="grid grid-cols-1 sm:grid-cols-3 gap-4 mb-8">
        <div class="bg-white dark-surface p-5 rounded-2xl border border-slate-200/80 dark-border shadow-sm">
          <p class="text-slate-400 dark-text-dim text-sm font-medium">Cursos</p>
          <h3 id="totalCourses" class="text-3xl font-bold text-slate-800 dark-text-primary mt-1">0</h3>
        </div>
        <div class="bg-white dark-surface p-5 rounded-2xl border border-slate-200/80 dark-border shadow-sm">
          <p class="text-slate-400 dark-text-dim text-sm font-medium">Apuntes</p>
          <h3 id="totalNotes" class="text-3xl font-bold text-slate-800 dark-text-primary mt-1">0</h3>
        </div>
        <div class="bg-white dark-surface p-5 rounded-2xl border border-slate-200/80 dark-border shadow-sm">
          <p class="text-slate-400 dark-text-dim text-sm font-medium">Última edición</p>
          <h3 id="lastUpdated" class="text-lg font-bold text-slate-800 dark-text-primary mt-1">—</h3>
        </div>
      </div>
      
      <!-- Course pills -->
      <div class="bg-white dark-surface p-4 rounded-2xl border border-slate-200/80 dark-border shadow-sm mb-6">
        <div class="flex items-center flex-wrap gap-2">
          <span class="text-xs font-bold text-slate-400 dark-text-dim uppercase mr-2">Cursos:</span>
          <div id="coursePills" class="flex flex-wrap gap-1.5 flex-1"></div>
          <button id="addCourseBtn" class="px-3 py-1.5 rounded-lg text-xs font-bold bg-slate-100 dark-muted-bg text-slate-500 dark-text-dim hover:bg-slate-200 dark-hover-surface transition-all">
            <i class="fas fa-plus mr-1"></i>Curso
          </button>
        </div>
      </div>

      <!-- Course form (hidden by default) -->
      <div id="courseFormContainer" class="hidden bg-white dark-surface p-5 rounded-2xl border border-slate-200/80 dark-border shadow-sm mb-6">
        <div class="flex flex-col sm:flex-row gap-4 items-end">
          <div class="flex-1">
            <label class="block text-xs font-bold text-slate-400 dark-text-dim uppercase mb-1 ml-1">Nombre del Curso</label>
            <input type="text" id="courseNameInput" placeholder="Ej. Cálculo I" required
              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark-input focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none transition-all">
          </div>
          <div class="flex items-center gap-2">
            <div id="colorPresets" class="flex gap-1.5"></div>
            <button id="saveCourseBtn" class="px-6 py-2.5 bg-gradient-to-r from-indigo-500 to-purple-600 text-white font-bold rounded-xl hover:from-indigo-600 hover:to-purple-700 shadow-lg transition-all">
              <i class="fas fa-plus mr-1.5"></i>Crear
            </button>
            <button id="cancelCourseBtn" class="px-4 py-2.5 rounded-xl border border-slate-200 dark-border text-sm font-semibold text-slate-500 dark-text-dim hover:bg-slate-50 dark-hover-surface transition-all">
              Cancelar
            </button>
          </div>
        </div>
      </div>

      <!-- Notes section (hidden when no course selected) -->
      <div id="notesSection" class="hidden">
        <div class="relative mb-6">
          <i class="fas fa-search absolute left-4 top-1/2 -translate-y-1/2 text-slate-400 dark-text-dim"></i>
          <input type="text" id="searchInput" placeholder="Buscar apuntes..." 
            class="w-full pl-10 pr-4 py-2.5 rounded-xl border border-slate-200 dark-input focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none transition-all text-sm">
        </div>

        <!-- New note form -->
        <div class="bg-white dark-surface p-4 rounded-2xl border border-slate-200/80 dark-border shadow-sm mb-4">
          <button id="newNoteBtn" class="w-full py-2 text-sm font-semibold text-slate-400 dark-text-dim hover:text-indigo-600 transition-all border-2 border-dashed border-slate-200 dark-border rounded-xl hover:border-indigo-300">
            <i class="fas fa-plus mr-1.5"></i>Nuevo Apunte
          </button>
          <div id="newNoteForm" class="hidden mt-4 space-y-3">
            <input type="text" id="newNoteTitle" placeholder="Título del apunte" 
              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark-input focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none transition-all text-sm font-semibold">
            <textarea id="newNoteContent" rows="4" placeholder="Escribe tu apunte aquí..."
              class="w-full px-4 py-2.5 rounded-xl border border-slate-200 dark-input focus:ring-2 focus:ring-indigo-500 focus:border-transparent outline-none transition-all text-sm resize-none"></textarea>
            <div class="flex gap-2 justify-end">
              <button id="cancelNewNoteBtn" class="px-4 py-2 rounded-xl border border-slate-200 dark-border text-sm font-semibold text-slate-500 dark-text-dim hover:bg-slate-50 dark-hover-surface transition-all">
                Cancelar
              </button>
              <button id="saveNewNoteBtn" class="px-6 py-2 bg-gradient-to-r from-indigo-500 to-purple-600 text-white font-bold rounded-xl hover:from-indigo-600 hover:to-purple-700 shadow-lg transition-all text-sm">
                <i class="fas fa-save mr-1.5"></i>Guardar
              </button>
            </div>
          </div>
        </div>

        <!-- Notes list -->
        <div id="notesList" class="space-y-3"></div>

        <!-- Empty state -->
        <div id="notesEmpty" class="text-center py-20">
          <div class="w-20 h-20 bg-slate-100 dark-muted-bg rounded-3xl flex items-center justify-center mx-auto mb-5">
            <i class="fas fa-sticky-note text-slate-300 dark-empty-icon text-3xl"></i>
          </div>
          <h2 class="text-xl font-semibold text-slate-400 dark-text-dim">Sin apuntes aún</h2>
          <p class="text-slate-400 dark-text-dim text-sm mt-1">Agrega tu primer apunte en este curso</p>
        </div>
      </div>

      <!-- No courses empty state -->
      <div id="noCoursesEmpty" class="text-center py-20">
        <div class="w-20 h-20 bg-slate-100 dark-muted-bg rounded-3xl flex items-center justify-center mx-auto mb-5">
          <i class="fas fa-folder-open text-slate-300 dark-empty-icon text-3xl"></i>
        </div>
        <h2 class="text-xl font-semibold text-slate-400 dark-text-dim">Sin cursos aún</h2>
        <p class="text-slate-400 dark-text-dim text-sm mt-1">Crea un curso para empezar a tomar apuntes</p>
      </div>

    </div>
  </main>

  <script is:inline src="/apuntes.js"></script>
</BaseLayout>
